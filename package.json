{
  "name": "wikipedia-destinations",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler pages dev public --port 8788",
    "build": "tsc -b && vite build",
    "preview": "npm run build && wrangler pages dev dist",
    "typecheck": "tsc -b",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260723.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "wrangler": "^4.113.0"
  }
}
